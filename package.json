{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3001 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "scrape:popmart": "node scripts/scrape-popmart.mjs",
    "scrape:popmart:ip-images": "node scripts/scrape-popmart-ip-images.mjs",
    "scrape:koca": "node scripts/scrape-koca.mjs",
    "check:supabase": "node scripts/check-supabase.mjs",
    "db:check": "node scripts/check-database.mjs",
    "test:integration": "node scripts/integration-smoke.mjs",
    "test:backend": "cd backend && PYTHONPATH=src python -m unittest discover -s tests -p 'test_*.py'",
    "db:current": "cd backend && python -m alembic current",
    "db:migrate": "cd backend && python -m alembic upgrade head",
    "db:stamp": "cd backend && python -m alembic stamp head",
    "db:seed": "node scripts/run-backend-python.mjs backend/scripts/seed_catalog.py",
    "db:seed:replace": "node scripts/run-backend-python.mjs backend/scripts/seed_catalog.py --replace --no-dev-user",
    "db:seed:koca": "npm run db:seed",
    "db:seed:koca:full": "node scripts/run-backend-python.mjs backend/scripts/seed_koca_full.py",
    "db:seed:koca:replace": "npm run db:seed:replace",
    "db:seed:demo": "node scripts/run-backend-python.mjs backend/scripts/seed_dev_demo.py",
    "db:seed:split-box": "node scripts/run-backend-python.mjs backend/scripts/seed_split_box_demo.py",
    "db:seed:all": "npm run db:seed && npm run db:seed:demo",
    "db:reset:seed": "node scripts/run-backend-python.mjs backend/scripts/reset_and_seed_all.py",
    "db:seed:dry": "node scripts/run-backend-python.mjs backend/scripts/seed_catalog.py --dry-run",
    "db:refresh-heat": "node scripts/run-backend-python.mjs backend/scripts/refresh_catalog_heat.py",
    "db:compute-heat": "node scripts/run-backend-python.mjs backend/scripts/refresh_catalog_heat.py --compute-only",
    "db:downgrade": "cd backend && python -m alembic downgrade -1",
    "db:revision": "cd backend && python -m alembic revision --autogenerate",
    "backend:dev": "node scripts/backend-dev.mjs",
    "backend:install": "cd backend && pip install -r requirements.txt"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.106.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
