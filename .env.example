# --- Supabase（前端 Vite）---
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# 可選：service role（僅後端腳本，勿提交、勿暴露於前端）
# SUPABASE_SERVICE_ROLE_KEY=

# --- PostgreSQL（Alembic / 後端資料層）---
# 與 VITE_SUPABASE_ANON_KEY 不同。請從 Dashboard → Database → Connect 複製連線字串。
#
# 方式 A（推薦）：Session pooler 完整 URI
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
#
# 方式 B：密碼 + 區域（自動組裝 pooler，勿手動拼 db.xxx.supabase.co）
# SUPABASE_DB_PASSWORD=[PASSWORD]
# SUPABASE_DB_REGION=ap-southeast-1
#
# 驗證：npm run db:check && npm run db:migrate

# --- 前端假資料（Joe 分支圖鑑 JSON，無需後端即可測 UI）---
# 設為 false 時改走 VITE_API_URL 的 Catalog / Listings API
VITE_USE_MOCK_DATA=true

# --- FastAPI 後端 ---
# 前端連線後端 API 的 base URL（純 UI 模式）
VITE_API_URL=http://localhost:8000

# 開發用使用者 UUID（X-User-Id header，由前端隨每個 API 請求送出）
# 使用 npm run db:seed 種子後會自動輸出此 UUID
VITE_DEV_USER_ID=

# （已不再需要，可移除）
# VITE_DATA_SOURCE=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
